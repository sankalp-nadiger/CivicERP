PORT=3000
MONGO_URI=mongodb://localhost:27017/civicerp

# AWS S3 upload configuration (required for POST /uploads/presign)
AWS_REGION=eu-north-1
# Optional fallback key recognized by AWS SDK / this app
AWS_DEFAULT_REGION=eu-north-1
AWS_S3_BUCKET=your-bucket-name

# On Render, set these explicitly unless using an attached AWS IAM role.
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# Optional: CloudFront/custom public base URL for uploaded objects.
# Example: https://cdn.example.com
AWS_S3_PUBLIC_BASE_URL=

#google gemini api key
GOOGLE_API_KEY=
