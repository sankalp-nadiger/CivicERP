# Server Environment Variables
MONGO_URI="your_mongodb_connection_string"

# JWT Secret Key
JWT_SECRET="your_jwt_secret_key_change_in_production"

# Email Configuration (Gmail)
USER_EMAIL="your_email@gmail.com"
USER_PASS="your_app_password"

# LibreTranslate (used for dynamic/free-text translations)
# If running locally via Docker: http://localhost:5000
LIBRETRANSLATE_URL="http://localhost:5000"
# Optional (most self-hosted instances don't require it)
LIBRETRANSLATE_API_KEY=""
# Usually "auto" is best
LIBRETRANSLATE_SOURCE_LANG="auto"

# Optional Gemini API key (used for other AI features if any)
GEMINI_API_KEY=""
API_KEY=""



# Frontend URL
FRONTEND_URL="http://localhost:5173"

# Port (Optional)
PORT=3000


# =========================
# AWS S3 (Complaint Photo Uploads)
# =========================
# Required for /uploads/presign
AWS_REGION="eu-north-1"
AWS_S3_BUCKET="civicerp-imgs-bucket"

# Credentials (ONLY on server; never expose these in client code)
# For production, prefer IAM Role/Task Role and leave these unset.
AWS_ACCESS_KEY_ID="AKIASO7YGF4ZGU2K5X2F"
AWS_SECRET_ACCESS_KEY="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"
# Only if you use temporary credentials (STS)
AWS_SESSION_TOKEN=""

# Optional: public base URL for viewing uploaded objects (e.g., CloudFront)
# If not set, server returns the standard S3 URL:
# https://<bucket>.s3.<region>.amazonaws.com/<key>
AWS_S3_PUBLIC_BASE_URL=""
