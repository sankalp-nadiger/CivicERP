{
  "compilerOptions": {
    "target": "ES2020",               // Keep the target as ES2020
    "module": "ESNext",               // Change module system to ES modules
    "outDir": "./dist",               // The directory where compiled files will be stored
    "rootDir": "./src",               // Root directory for your source files
    "strict": true,                   // Enable strict type-checking options
    "esModuleInterop": true,          // Allow default imports from CommonJS modules
    "moduleResolution": "bundler",    // Use bundler module resolution for .ts extensions
    "allowImportingTsExtensions": true, // Allow .ts extensions in imports
    "noEmit": true,                   // Don't emit files (bundler will handle this)
    "resolveJsonModule": true,        // Allow importing JSON files as modules
    "skipLibCheck": true              // Skip checking type definitions in node_modules
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
